# ==============================================================================
# Python / Build / OS
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/
.DS_Store
Thumbs.db

# ==============================================================================
# Environment & Secrets
# ==============================================================================
.env
.env.local
.env.*
!.env.example

# ==============================================================================
# Virtual Environments
# ==============================================================================
.venv/
venv/
env/

# ==============================================================================
# Testing & Coverage
# ==============================================================================
.coverage
htmlcov/
coverage.xml
*.log

# ==============================================================================
# Caching & Temp Files
# ==============================================================================
.mypy_cache/
.ruff_cache/
.pytest_cache/
.ipynb_checkpoints/
.jupyter/

# ==============================================================================
# IDE / Editor (Local only)
# ==============================================================================
# Ignore IDE folders except intentionally shared workspace settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ==============================================================================
# Data Files (Raw / Temporary / Large)
# ==============================================================================
/data/
/logs/
/runs/
/tb_logs/
*.nc
*.nc4
*.hdf
*.hdf5
/data/**/*.dat

# ==============================================================================
# ML / Experiment Artifacts
# ==============================================================================
/output/
*.pt
*.pth
*.ckpt
*.joblib
*.pkl


# ==============================================================================
# Output Images
# ==============================================================================
# Prevent accidental tracking of generated map figures
/output/**/*.jpg
/output/**/*.jpeg
/output/**/*.png
/output/**/*.gif
/output/**/*.bmp
