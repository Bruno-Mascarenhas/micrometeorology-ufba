# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# ==============================================================================
# Virtual environments
# ==============================================================================
.venv/
venv/
env/

# ==============================================================================
# IDE / Editor
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================================================
# Data files (large, not tracked)
# Only ignore the top-level data/ directory, not sub-packages named data/
# ==============================================================================
/data/
/logs/
*.nc
*.nc4
*.hdf
*.hdf5

# Sensor .dat files only in the top-level data directory
/data/**/*.dat

# ==============================================================================
# Site output data (heavy JSON/GeoJSON files generated by WRF processing)
# Keep site HTML/CSS/JS tracked, exclude generated data
# ==============================================================================
site/JSON/
site/GeoJSON/
site/videos/
site/figuras/
site/*.webm
site/*.mp4
site/*.gif

# ==============================================================================
# Image files (generated outputs, not source assets)
# Only in output directories, not in docs/ or site/ assets
# ==============================================================================
/output/**/*.jpg
/output/**/*.jpeg
/output/**/*.png
/output/**/*.gif
/output/**/*.bmp

# ==============================================================================
# Jupyter / IPython
# ==============================================================================
.ipynb_checkpoints/

# ==============================================================================
# OS files
# ==============================================================================
.DS_Store
Thumbs.db

# ==============================================================================
# Cache / Temp
# ==============================================================================
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ==============================================================================
# ML / Experiment artifacts (generated at runtime, not source code)
# ==============================================================================
/output/
*.pt
*.pth
*.ckpt
*.joblib
*.pkl
