      ╔═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
      ║ 0) O QUE SERA EXECUTADO?                                                                                                                                                      ║
      ║ ~~~~~~~~~~~~~~~~~~~~~~~~                                                                                                                                                      ║
      ╚═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝
processo_binario  = N     !se S-SIM/N-NAO, executa o *.bin, caso contario o *.scpt

╔═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
║PROCESSO A SER EXECUTADO           VERSAO                                        EXECUTAR (S-SIM/N-NAO)        LINGUAGEM  O QUE FAZ                                                  ║
╠═══════════════════════════════════╬═════════════════════════════════════════════╬═════════════════════════════╬══════════╬══════════════════════════════════════════════════════════╣

VERSAO_NAMELIST                   = 4.0.0                                                                       !        - controle de versao do namelist
processa_wrf_system               = processa_wrf_00_system-V3.1.0                 S                             !SHELL   - controle de processos
processa_wrf_busca                = processa_wrf_01_busca-V2.0.0                  N                             !SHELL   - busca de dados do GFS
processa_wrf_wps                  = processa_wrf_02_wps-V2.0.0                    N                             !SHELL   - processa o WPS
processa_wrf_wrf                  = processa_wrf_03_wrf-V2.0.0                    N                             !SHELL   - processa o WRF
processa_wrf_python               = processa_wrf_04_python-V2.0.0                 S                             !SHELL   - formata dados para o python
processa_wrf_figuras              = processa_wrf_04.1_figuras-V1.0.3.py           S                             !PYTHON  - gera das figuras no python
processa_wrf_mmif                 = processa_wrf_05_mmif-V2.0.0                   S                             !SHELL   - processa os dados do MMIF
processa_wrf_wap                  = processa_wrf_05.1_wap-V1.0.1.py               S                             !PYTHON  - gera das figuras no python do aermod
processa_wrf_readwrfnc            = processa_wrf_06_readwrfnc-V2.1.0              S                             !SHELL   - formata dados para o READ_WRF_NC
processa_wrf_interativemap        = processa_wrf_07_interative-map-V1.0.0         S                             !SHELL   - gera as figuras para os mapas interativos
processa_wrf_geoJSON              = processa_wrf_07.1_geojson-V1.0.0.py           S                             !PYTHON  - gera as figuras geoTIFF
processa_wrf_ftp                  = processa_wrf_08_ftp-V2.0.0                    N                             !SHELL   - envia os dados para o portal ufes
processa_wrf_deletafiles          = processa_wrf_09_deletafiles-V1.1.2            N                             !SHELL   - deleta arquivos antigos (>30 dias)
VERSAO_WPS                        = 4.7.1                                                                       !FORTRAN - versao do WPS
VERSAO_WRF                        = 4.7.1                                                                       !FORTRAN - versao do WRF
VERSAO_MMIF                       = 4.1.1                                                                       !FORTRAN - versao do MMIF

╚═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝

       ╔══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
       ║1) CONFIGURACAO DOS NAMELISTs DO WRF                                                                                                                                          ║
       ║~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~                                                                                                                                          ║
       ║├── time_step        ───  passo no tempo                                                                                                                                      ║
       ║├── numproc          ───  numero de processadores utilizados                                                                                                                  ║
       ║├── WPSoutput        ───  local de saida do WPS                                                                                                                               ║
       ║├── WRFoutput        ───  local de saida do WRF                                                                                                                               ║
       ║├── DATAhistory      ───  local dos dados diarios                                                                                                                             ║
       ║├── DATAtype         ┬──  gfs-0.50°   ───    default com ~54 km - (tipo de dados)                                                                                             ║
       ║│                    ├──  gfs-0.25°   ───    ~27 km - roda operacional se comecar as 6 horas da manha                                                                         ║
       ║│                    ├──  fnl         ───    dados historicos com ~54 km                                                                                                      ║
       ║│                    └──  gdas        ───    dados historicos com ~27 km                                                                                                      ║
       ║├── DATAgeog         ─── local dos dados geograficos                                                                                                                          ║
       ║├── geog_data_res    ─── topografia e uso do solo                                                                                                                             ║
       ║├── interval_seconds ─── intervalo de leitura dos arquivos: gfs (3 em 3 horas = 10800 s) - fnl ou gdas (6 em 6 horas = 21600 s)                                               ║
       ║└── wudapt_op        ─── opcao do wudapt                                                                                                                                      ║
       ╚══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝

╔═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗

time_step        = 160
numproc          = 36
WPSoutput        = /home/models/WRF/wrf-op/d-input
WRFoutput        = /home/models/WRF/wrf-op/d-output
DATAhistory      = /home/models/WRF/wrf-op/d-input
DATAtype         = gfs-0.50
DATAgeog         = /home/models/WRF/wrf-geog
geog_data_res    = cglc_modis_lcz+usgs+srmt+default
interval_seconds = 10800
wudapt_op        = S

╚═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝

       ╔══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
       ║2) WRF - CONFIGURACAO (execucao inicial e final)                                                                                                                              ║
       ║~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~                                                                                                                              ║
       ║├── wrf_ini         ─── execucao inicial do wrfxx em 1                                                                                                                        ║
       ║├── wrf_fin         ─── execucao final   do wrfxx em 10 (se desejar aumentar o n.° de linhas)                                                                                 ║
       ║├── wrf no.         ─── (VARIAVEL RESERVADA) configuracao do no. do projeto - No. = 01, 02, 03 etc.                                                                           ║
       ║├── exe_simulacao   ─── executa a simulacao (S-SIM/N-NAO)                                                                                                                     ║
       ║├── projeto         ┬── nome do projeto (preferencialmente em maiusculo)                                                                                                      ║
       ║│                   └── fazer os arquivos dentro de d-namelist (lista-json, namelist.wps e namelist.input)                                                                    ║
       ║├── num_max_dom     ─── quantidade de dominios do wrf (1, 2, 3, 4, 5 etc.)                                                                                                    ║
       ║├── deltahora       ┬── tempo de simulacao (horas). e.g., 03, 06, 75 (tem que colocar o zero para mumeros menores do que 10)                                                  ║
       ║│                   └── deltahora  eh SEMPRE de 3 em 3 horas (GFS)                                                                                                            ║
       ║├── lat_central     ─── latitude central do wrf                                                                                                                               ║
       ║├── lon_central     ─── longitude central do wrf                                                                                                                              ║
       ║├── localidade_ini  ─── eh a localidade inicial de extracao dos dados e figuras                                                                                               ║
       ║├── localidade_fin  ─── eh a localidade  final  de extracao dos dados e figuras                                                                                               ║
       ║├── wrf_ini = 1     ─── execucao inicial do wrfxx em 1                                                                                                                        ║
       ║└── wrf_fin = 4     ─── execucao final   do wrfxx em 10 (se desejar aumentar o n.° de linhas)                                                                                 ║
       ╚══════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝

wrf_ini      = 1
wrf_fin      = 5

╔═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
║simulacao         projeto          num_max_dom    deltahora    lat_central    lon_central    localidade_ini    localidade_fin                                                        ║
